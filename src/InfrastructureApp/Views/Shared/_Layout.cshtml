@using InfrastructureApp.Models
@using InfrastructureApp.Services
@using Microsoft.AspNetCore.Identity
@using InfrastructureApp.ViewComponents
@inject UserManager<Users> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PatchNotes</title>
    @if (ViewData["OgUrl"] != null)
    {
        <meta property="og:type" content="website" />
        <meta property="og:url" content="@ViewData["OgUrl"]" />
        <meta property="og:title" content="@ViewData["OgTitle"]" />
        <meta property="og:description" content="@ViewData["OgDescription"]" />
        @if (ViewData["OgImage"] != null)
        {
            <meta property="og:image" content="@ViewData["OgImage"]" />
        }
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
                /* Navbar / brand */
                .navbar-brand {
                    font-weight: bold;
                    letter-spacing: 1px;
                    color: var(--safety-orange) !important;
                }

                nav.navbar {
                    background-color: #1E1E1E !important;
                    border-bottom-color: var(--dark-border) !important;
                }

                .nav-link {
                    color: var(--text-primary) !important;
                }

                .nav-link:hover {
                    color: var(--safety-orange) !important;
                }

                /* Active nav link */
                .nav-link.active {
                    color: var(--safety-yellow) !important;
                }

                /* Footer */
                footer {
                    background-color: #1E1E1E;
                    color: var(--text-muted) !important;
                }

                footer a {
                    color: var(--text-muted) !important;
                }

                footer a:hover {
                    color: var(--safety-orange) !important;
                }

                .xp-bar {
                    height: 4px;
                    width: 100px;
                    background: var(--dark-border);
                    display: inline-block;
                    vertical-align: middle;
                    margin-left: 10px;
                }

                .xp-fill {
                    height: 100%;
                    background: var(--safety-orange);
                    width: 75%;
                }

                .user-level-badge {
                    background: var(--safety-orange);
                    color: white;
                    border-radius: 50%;
                    padding: 5px 10px;
                    font-size: 0.8rem;
                }
    </style>
</head>

<body>
    <header>
         <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">
                    <i class="fa-solid fa-city"></i> PatchNotes
                </a>
                
                @{
                    string avatarUrl = AvatarCatalog.ToUrl(null); // default fallback

                    if (User?.Identity?.IsAuthenticated == true)
                    {
                        var currentUser = await UserManager.GetUserAsync(User);

                        if (!string.IsNullOrWhiteSpace(currentUser?.AvatarUrl))
                            avatarUrl = currentUser.AvatarUrl;          // uploaded photo wins
                        else
                            avatarUrl = AvatarCatalog.ToUrl(currentUser?.AvatarKey); // preset fallback
                    }
                }
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="d-flex align-items-center gap-2">

                        <img src="@avatarUrl"
                             alt="Avatar"
                             style="width:34px;height:34px;border-radius:50%;object-fit:cover;"/>
                    </div>
                }
                <div class="d-flex align-items-center gap-2">
             
                    @await Component.InvokeAsync(typeof(UserAvatarViewComponent))
                </div>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#gameMenu"
                        aria-controls="gameMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="gameMenu">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index"><i class="fa-solid fa-map"></i> Home</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ReportIssue" asp-action="ReportIssue">
                                    <i class="fa fa-car"></i> Report Issue
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PointsShop" asp-action="Index">
                                    <i class="fa-solid fa-store"></i> Points Shop
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Minigames" asp-action="Index">
                                    <i class="fa-solid fa-gamepad"></i> Minigames
                                </a>
                            </li>
                         @* <li class="nav-item">
                                <a class="nav-link" href="/Achievements"><i class="fa-solid fa-medal"></i> Badges</a>
                            </li> *@
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="RoadCamera" asp-action="Index"><i class="fa-solid fa-video"></i> Road Cameras </a>
                            </li>
                        }   
                        <li class="nav-item">
                            <a class="nav-link" href="/Reports/Latest">
                                <i class="fa-solid fa-scroll"></i> Latest
                                Reports
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="NearbyIssue" asp-action="Index">
                                <i class="fa-solid fa-map-pin"></i> Nearby Issues
                            </a>
                        </li>
                         @if (User?.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Account" asp-action="ChooseAvatar"><i class="fa-solid fa-user"></i> Choose Avatar</a>
                                </li>
                                if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-controller="Account" asp-action="Admin"><i class="fa-solid fa-arrow-pointer"></i> Admin Page</a>
                                    </li>
                                }
                            }
                        @if (User.IsInRole("Admin") || User.IsInRole("Moderator"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Moderation" asp-action="Index">
                                    <i class="fa-solid fa-shield-halved"></i> Moderation
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
                </div>
            </nav>
        </header>

        <div class="container mt-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <!-- Flag Modal -->
        <div class="modal" id="flagModal" tabindex="-1" aria-labelledby="flagModalLabel" aria-hidden="true" style="z-index: 1060;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="flagModalLabel"><i class="fa-solid fa-flag me-2 text-danger"></i>Report Inappropriate Content</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Please select a reason for flagging this content:</p>
                        <form id="flagForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" id="flagReportId" name="reportId" value="" />
                            <div class="mb-3">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="category" id="catMisinfo" value="Misinformation" checked>
                                    <label class="form-check-label" for="catMisinfo">Misinformation</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="category" id="catSpam" value="Spam">
                                    <label class="form-check-label" for="catSpam">Spam</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="category" id="catInvalid" value="Invalid report">
                                    <label class="form-check-label" for="catInvalid">Invalid report</label>
                                </div>
                            </div>
                        </form>
                        <div id="flagMessage" class="alert d-none" role="alert"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" id="submitFlagBtn" class="btn btn-danger">Submit Report</button>
                    </div>
                </div>
            </div>
        </div>

        <footer class="border-top border-secondary text-muted mt-5">
            <div class="container py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span>&copy; @DateTime.Now.Year - PatchNotes</span>
                <div class="d-flex gap-3">
                    <a asp-controller="Home" asp-action="FAQ" class="text-decoration-none text-muted">
                        <i class="fa-solid fa-circle-question me-1"></i>FAQ
                    </a>
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted">
                        Privacy Policy
                    </a>
                    <a asp-controller="Home" asp-action="About" class="text-decoration-none text-muted">About</a>
                </div>
            </div>
        </footer>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>


        <!-- Google Translate initialization -->
        <script>
            function googleTranslateElementInit() {
                new google.translate.TranslateElement(
                    {
                        pageLanguage: 'en',
                        includedLanguages: 'en,es,zh-CN',
                        layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
                        autoDisplay: false
                    },
                    'google_translate_element'
                );
            }
        </script>

        <!-- Google Translate loader -->
        <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

        @await RenderSectionAsync(name: "Scripts", required: false)
        
    </body>

</html>
