@using InfrastructureApp.Models
@using InfrastructureApp.Services
@using Microsoft.AspNetCore.Identity
@inject UserManager<Users> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PatchNotes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header>
         <nav class="navbar navbar-expand-lg pn-navbar" aria-label="Main navigation">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">
                    <i class="fa-solid fa-city"></i> PatchNotes
                </a>
                
                @{
                    string avatarUrl = AvatarCatalog.ToUrl(null); // default fallback

                    if (User?.Identity?.IsAuthenticated == true)
                    {
                        var currentUser = await UserManager.GetUserAsync(User);

                        if (!string.IsNullOrWhiteSpace(currentUser?.AvatarUrl))
                            avatarUrl = currentUser.AvatarUrl;          // uploaded photo wins
                        else
                            avatarUrl = AvatarCatalog.ToUrl(currentUser?.AvatarKey); // preset fallback
                    }
                }
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="d-flex align-items-center gap-2">

                        <img src="@avatarUrl"
                             alt="Avatar"
                             style="width:34px;height:34px;border-radius:50%;object-fit:cover;"/>
                    </div>
                }
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#gameMenu"
                        aria-controls="gameMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="gameMenu">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index"><i class="fa-solid fa-map"></i> Home</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ReportIssue" asp-action="ReportIssue">
                                    <i class="fa fa-car"></i> Report Issue
                                </a>
                            </li>
                         @* <li class="nav-item">
                                <a class="nav-link" href="/Achievements"><i class="fa-solid fa-medal"></i> Badges</a>
                            </li> *@
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="RoadCamera" asp-action="Index"><i class="fa-solid fa-video"></i> Road Cameras </a>
                            </li>
                        }   
                        <li class="nav-item">
                            <a class="nav-link" href="/Reports/Latest">
                                <i class="fa-solid fa-scroll"></i> Latest
                                Reports
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="NearbyIssue" asp-action="Index">
                                <i class="fa-solid fa-map-pin"></i> Nearby Issues
                            </a>
                        </li>
                         @if (User?.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Account" asp-action="ChooseAvatar"><i class="fa-solid fa-user"></i> Choose Avatar</a>
                                </li>
                                if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-controller="Account" asp-action="Admin"><i class="fa-solid fa-arrow-pointer"></i> Admin Page</a>
                                    </li>
                                }
                            }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
                </div>
            </nav>
        </header>

        <div class="container mt-4">
            <main id="main-content" role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>


        <footer class="pn-footer mt-5">
            <div class="container py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span>&copy; @DateTime.Now.Year - PatchNotes</span>
                <div class="d-flex gap-3">
                    <a asp-controller="Home" asp-action="FAQ" class="text-decoration-none text-muted">
                        <i class="fa-solid fa-circle-question me-1"></i>FAQ
                    </a>
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted">
                        Privacy Policy
                    </a>
                    <a asp-controller="Home" asp-action="About" class="text-decoration-none text-muted">About</a>
                </div>
            </div>
        </footer>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>


        <!-- Google Translate initialization -->
        <script>
            function googleTranslateElementInit() {
                new google.translate.TranslateElement(
                    {
                        pageLanguage: 'en',
                        includedLanguages: 'en,es,zh-CN',
                        layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
                        autoDisplay: false
                    },
                    'google_translate_element'
                );
            }
        </script>

        <!-- Google Translate loader -->
        <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

        @await RenderSectionAsync(name: "Scripts", required: false)
        
    </body>

</html>