@model InfrastructureApp.Models.ReportIssue
@using InfrastructureApp.Configuration
@using Microsoft.Extensions.Options


<!--injects API key, avoids using viewbag-->
@inject IOptions<GoogleMapsOptions> GoogleMaps  

@{
    ViewData["Title"] = "Submit Issue";
}

@if (!string.IsNullOrWhiteSpace(Model.CameraImageUrl))
{
    <div class="mb-4">
        <h5>Reporting issue for this camera:</h5>
        <img src="@Model.CameraImageUrl"
            class="img-fluid rounded shadow-sm"
            style="max-height: 300px;" />
    </div>
}      
<!--report issue submission form-->
<div class="container py-4">
    <h1 class="h3 mb-3">Issue Submission Form</h1>

    <div asp-validation-summary="All" class="text-danger mb-3"></div>


    <form asp-action="Create" asp-controller="ReportIssue" method="post" enctype="multipart/form-data">   <!--enctype is required for photo uploads-->
        @Html.AntiForgeryToken()

        <input asp-for="CameraId" type="hidden" />
        <input asp-for="CameraImageUrl" type="hidden" />

        <!--text box-->
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>

            <div class="position-relative">
                <textarea asp-for="Description"
                        id="Description"
                        class="form-control"
                        maxlength="300"
                        rows="5"
                        spellcheck="true"
                        placeholder="Describe the infrastructure issue here. Add a clear description and the location. (300 characters max)"
                        aria-label="Issue description"></textarea>

                <div id="descriptionSuggestions" class="autocomplete-dropdown d-none"></div>
            </div>

            <span asp-validation-for="Description" class="text-danger"></span>

            <div class="form-text">
                <span>Character Count: </span>
                <span id="descCount">0</span>/300
            </div>
        </div>

        <!--picture upload-->
       @if (string.IsNullOrWhiteSpace(Model.CameraImageUrl))
        {
            <div class="mb-3">
                <label asp-for="Photo" class="form-label"></label>
                <input asp-for="Photo" type="file" class="form-control" />
                <span asp-validation-for="Photo" class="text-danger"></span>
            </div>
        }

        <!--map-->
        <div class="mb-3">
            <label class="form-label">Select location</label>
            <div id="map" style="height: 380px; width: 100%; border-radius: 12px;"></div>
            <small class="text-muted">Click on the map to drop a marker where the issue happened.</small>
            <span asp-validation-for="Latitude" class="text-danger d-block"></span>
            <span asp-validation-for="Longitude" class="text-danger d-block"></span>
        </div>

        <!--hidden inputs that get populated by javascript-->
        <input asp-for="Latitude" type="hidden" id="Latitude" />
        <input asp-for="Longitude" type="hidden" id="Longitude" />

        <button type="submit"
                class="btn report-action-btn report-action-btn--primary"
                aria-label="Submit the issue report">
            Submit
        </button>

        <a class="btn report-action-btn ms-2"
           asp-action="ReportIssue"
           aria-label="Cancel and return to report issue page">
            Cancel
        </a>
    </form>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/reportIssue.js"></script>
    <script src="~/js/reportAssist.js"></script>

    <script async defer
            src="https://maps.googleapis.com/maps/api/js?key=@GoogleMaps.Value.ApiKey&callback=initMap">
    </script>
}


