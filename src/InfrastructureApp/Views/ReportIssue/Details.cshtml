@using InfrastructureApp.Configuration
@using Microsoft.Extensions.Options

<!--injects API key, avoids using viewbag-->
@inject IOptions<GoogleMapsOptions> GoogleMaps


@model InfrastructureApp.Models.ReportIssue
@{
    ViewData["Title"] = "Report Submitted";
    var reporterDisplay = !string.IsNullOrWhiteSpace(Model.User?.UserName)
        ? Model.User!.UserName
        : !string.IsNullOrWhiteSpace(Model.User?.Email)
            ? Model.User!.Email
            : "Unknown user";

    if (Model.Status == "Approved")
    {
        var issueUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/ReportIssue/Details/{Model.Id}";
        ViewData["OgUrl"] = issueUrl;
        ViewData["OgTitle"] = "Infrastructure Issue on PatchNotes";
        ViewData["OgDescription"] = Model.Description;
        if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            var imgUrl = Model.ImageUrl.StartsWith("/")
                ? $"{Context.Request.Scheme}://{Context.Request.Host}{Model.ImageUrl}"
                : Model.ImageUrl;
            ViewData["OgImage"] = imgUrl;
        }
    }
}

<div class="container py-4">
    <h1 class="h3 mb-3">Report Submitted</h1>

    @if (!string.IsNullOrWhiteSpace(Model.IssueName))
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="alert">
            <i class="fa-solid fa-tag fa-lg"></i>
            <span>The community named this issue <strong>&ldquo;@Model.IssueName&rdquo;</strong></span>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Success"]
        </div>
    }

    <div class="report-card">
        <p><strong>Status:</strong> @Model.Status</p>
        @{
            var severityClass = Model.SeverityStatus switch
            {
                "Low" => "bg-success",
                "Medium" => "bg-warning text-dark",
                "High" => "bg-danger",
                "Critical" => "bg-dark",
                _ => "bg-secondary"
            };
        }

        <p>
            <strong>Severity:</strong>
            <span class="badge @severityClass px-3 py-2" data-testid="severity-status">
                @Model.SeverityStatus
            </span>
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.SeverityReason))
        {
            <p>
                <strong>Reason:</strong><br />
                <span data-testid="severity-reason">@Model.SeverityReason</span>
            </p>
        }
        else
        {
            <p class="text-muted">
                <strong>Reason:</strong> <span data-testid="severity-reason">Not available.</span>
            </p>
        }
        <p><strong>Created:</strong> @Model.CreatedAt</p>
        <p><strong>Reported by:</strong> @reporterDisplay</p>
        <p>
            <strong>Description:</strong><br />
            <span class="report-text-wrap text-break">@Model.Description</span>
        </p>
        <p><strong>Location:</strong> (@Model.Latitude, @Model.Longitude)</p>

        <div class="mt-3">
            <p><strong>Location on map:</strong></p>

            <div id="submittedMap"   data-lat="@Model.Latitude"    data-lng="@Model.Longitude"
                 style="height:320px; width:100%; border-radius:12px;">
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <p><strong>Image:</strong></p>

            <!-- SCRUM-102 ADDED: hide broken image and show fallback message -->
            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="Uploaded issue photo"
                 onerror="this.classList.add('d-none'); document.getElementById('detailsImageFallback').classList.remove('d-none');" />

            <!-- SCRUM-102 ADDED: shown only if the image file cannot be loaded -->
            <p id="detailsImageFallback" class="text-muted d-none">
                Image could not be loaded.
            </p>
        }
        else
        {
            <!-- SCRUM-102 ADDED: fallback when no image URL exists -->
            <p class="text-muted">No image was provided for this report.</p>
        }
    </div>

    <!-- Admin actions -->
    @if (User.IsInRole("Admin"))
    {
        @if (Model.Status == "Approved")
        {
            <div class="mt-3 d-flex align-items-center gap-3">
                <form asp-action="MarkResolved" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="fa-solid fa-wrench me-1"></i>
                        Mark as Resolved
                    </button>
                </form>
                @if (ViewBag.VerifyCount > 0)
                {
                    <span class="text-muted">
                        <i class="fa-solid fa-circle-check text-success me-1"></i>
                        @ViewBag.VerifyCount community member@(ViewBag.VerifyCount == 1 ? "" : "s") verified this is fixed
                    </span>
                }
            </div>
        }
        else if (Model.Status == "Resolved")
        {
            <div class="mt-3">
                <form asp-action="MarkVerifiedFixed" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success fw-bold">
                        <i class="fa-solid fa-circle-check me-1"></i>
                        Approve as Verified Fixed
                    </button>
                </form>
            </div>
        }
    }

    <!-- Issue naming form (shown when threshold met and not yet named) -->
    @if (string.IsNullOrWhiteSpace(Model.IssueName) && (int)ViewBag.VoteCount >= (int)ViewBag.NamingThreshold)
    {
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="alert alert-info mt-4 mb-0" role="alert">
                <p class="mb-2 fw-bold"><i class="fa-solid fa-tag me-1"></i> This issue has enough community votes — give it a name!</p>
                @if (TempData["NameError"] != null)
                {
                    <div class="text-danger small mb-2">@TempData["NameError"]</div>
                }
                <form asp-action="NameIssue" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 align-items-center flex-wrap">
                    @Html.AntiForgeryToken()
                    <select name="name" class="form-select form-select-sm w-auto" required>
                        <option value="" disabled selected>Choose a name…</option>
                        @foreach (var n in (string[])ViewBag.AvailableNames)
                        {
                            <option value="@n">@n</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-warning btn-sm fw-bold">Name it!</button>
                </form>
            </div>
        }
    }

    <!-- Community actions row -->
    <div class="mt-4 d-flex gap-3">

        <!-- Vote -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <button id="voteBtn"
                    class="btn @(ViewBag.UserHasVoted ? "btn-primary" : "btn-outline-primary") fw-bold flex-fill py-2"
                    data-report-id="@Model.Id"
                    data-voted="@ViewBag.UserHasVoted.ToString().ToLower()">
                <i class="fa-solid fa-thumbs-up me-1"></i>
                I've seen this too
            </button>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary fw-bold flex-fill py-2 text-center">
                <i class="fa-solid fa-thumbs-up me-1"></i>
                I've seen this too
            </a>
        }

        <!-- Verify -->
        @if (Model.Status == "Approved")
        {
            @if (User.Identity?.IsAuthenticated == true)
            {
                <button id="verifyBtn"
                        class="btn @(ViewBag.UserHasVerified ? "btn-success" : "btn-outline-success") fw-bold flex-fill py-2"
                        data-report-id="@Model.Id">
                    <i class="fa-solid fa-circle-check me-1"></i>
                    I've verified this is fixed
                </button>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-success fw-bold flex-fill py-2 text-center">
                    <i class="fa-solid fa-circle-check me-1"></i>
                    I've verified this is fixed
                </a>
            }
        }
        else if (Model.Status == "Resolved")
        {
            <span class="badge bg-success fs-6 flex-fill py-2 text-center d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-circle-check me-1"></i> Resolved
            </span>
        }
        else
        {
            <div class="flex-fill"></div>
        }

        <!-- Flag -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <button type="button"
                    id="flagBtn"
                    data-testid="flag-button"
                    data-bs-toggle="modal"
                    data-bs-target="#flagModal"
                    aria-controls="flagModal"
                    onclick="window.showFlagModalFromButton?.(this)"
                    class="btn @(ViewBag.UserHasFlagged ? "btn-secondary" : "btn-outline-danger") fw-bold flex-fill py-2"
                    data-report-id="@Model.Id"
                    @(ViewBag.UserHasFlagged ? "disabled" : "")>
                <i class="fa-solid fa-flag me-1"></i>
                @(ViewBag.UserHasFlagged ? "Already Flagged" : "Flag Inappropriate Content")
            </button>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-danger fw-bold flex-fill py-2 text-center">
                <i class="fa-solid fa-flag me-1"></i>
                Flag Inappropriate Content
            </a>
        }

    </div>

    <!-- Vote / verify counts -->
    <div class="d-flex gap-3 mt-1">
        <small class="flex-fill text-center text-muted">
            <span id="voteCount">@ViewBag.VoteCount</span>
            community vote@(ViewBag.VoteCount == 1 ? "" : "s")
        </small>
        @if (Model.Status == "Approved")
        {
            <small class="flex-fill text-center text-muted">
                <span id="verifyCount">@ViewBag.VerifyCount</span>
                community verification@(ViewBag.VerifyCount == 1 ? "" : "s")
            </small>
        }
        else
        {
            <div class="flex-fill"></div>
        }
        <div class="flex-fill"></div>
    </div>

    <div class="mt-4 d-flex gap-3">
        <a class="btn report-action-btn flex-fill text-center py-2"
           asp-action="Create"
           aria-label="Report another issue">
            Report another Issue
        </a>

        <a class="btn report-action-btn flex-fill text-center py-2"
           asp-controller="Home"
           asp-action="Index"
           aria-label="Return to the home page">
            Back to Home
        </a>

        <a class="btn report-action-btn flex-fill text-center py-2"
           asp-controller="Reports"
           asp-action="Latest"
           aria-label="Return to latest reports">
            View Another Report
        </a>
    </div>

    @if (Model.Status == "Approved" && User.Identity?.IsAuthenticated == true)
    {
        var shareUrl = Uri.EscapeDataString($"{Context.Request.Scheme}://{Context.Request.Host}/ReportIssue/Details/{Model.Id}");
        var facebookShareUrl = $"https://www.facebook.com/sharer/sharer.php?u={shareUrl}";
        <div class="mt-2 d-flex gap-3">
            <div class="flex-fill"></div>
            <div class="flex-fill text-center">
                <p class="mb-1 small text-muted fw-bold">Share this issue:</p>
                <a href="@facebookShareUrl"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="btn btn-primary fw-bold"
                   aria-label="Share on Facebook">
                    <i class="fa-brands fa-facebook me-1"></i>
                    Facebook
                </a>
            </div>
            <div class="flex-fill"></div>
        </div>
    }
</div>

<!-- Canvas is OUTSIDE the container so viewport units work correctly -->
<canvas id="confetti-canvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:9999;display:none;"></canvas>

<partial name="_FlagReportModal" />

@section Scripts {
    @Html.AntiForgeryToken()

    <script src="~/js/reportIssue.js"></script>
    <script src="~/js/reportVote.js" asp-append-version="true"></script>
    <script src="~/js/reportVerify.js" asp-append-version="true"></script>
    <script src="~/js/reportFlag.js" asp-append-version="true"></script>

    <script async defer
        src="https://maps.googleapis.com/maps/api/js?key=@GoogleMaps.Value.ApiKey&callback=initSubmittedMap">
    </script>

     <script src="~/js/confetti.js"></script>

        @if (TempData["Success"] != null)
        {
            <text><script>setTimeout(launchConfetti, 500);</script></text>
        }
    
}
