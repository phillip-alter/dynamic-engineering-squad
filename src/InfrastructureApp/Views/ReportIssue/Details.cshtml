@using InfrastructureApp.Configuration
@using Microsoft.Extensions.Options

<!--injects API key, avoids using viewbag-->
@inject IOptions<GoogleMapsOptions> GoogleMaps


@model InfrastructureApp.Models.ReportIssue
@{
    ViewData["Title"] = "Report Submitted";
}

<div class="container py-4">
    <h1 class="h3 mb-3">Report Submitted</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Success"]
        </div>
    }

    <div class="report-card">
        <p><strong>Status:</strong> @Model.Status</p>
        @{
            var severityClass = Model.SeverityStatus switch
            {
                "Low" => "bg-success",
                "Medium" => "bg-warning text-dark",
                "High" => "bg-danger",
                "Critical" => "bg-dark",
                _ => "bg-secondary"
            };
        }

        <p>
            <strong>Severity:</strong>
            <span class="badge @severityClass px-3 py-2" data-testid="severity-status">
                @Model.SeverityStatus
            </span>
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.SeverityReason))
        {
            <p>
                <strong>Reason:</strong><br />
                <span data-testid="severity-reason">@Model.SeverityReason</span>
            </p>
        }
        else
        {
            <p class="text-muted">
                <strong>Reason:</strong> <span data-testid="severity-reason">Not available.</span>
            </p>
        }
        <p><strong>Created:</strong> @Model.CreatedAt</p>
        <p><strong>Description:</strong><br />@Model.Description</p>
        <p><strong>Location:</strong> (@Model.Latitude, @Model.Longitude)</p>

        <div class="mt-3">
            <p><strong>Location on map:</strong></p>

            <div id="submittedMap"   data-lat="@Model.Latitude"    data-lng="@Model.Longitude"
                 style="height:320px; width:100%; border-radius:12px;">
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <p><strong>Image:</strong></p>

            <!-- SCRUM-102 ADDED: hide broken image and show fallback message -->
            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="Uploaded issue photo"
                 onerror="this.classList.add('d-none'); document.getElementById('detailsImageFallback').classList.remove('d-none');" />

            <!-- SCRUM-102 ADDED: shown only if the image file cannot be loaded -->
            <p id="detailsImageFallback" class="text-muted d-none">
                Image could not be loaded.
            </p>
        }
        else
        {
            <!-- SCRUM-102 ADDED: fallback when no image URL exists -->
            <p class="text-muted">No image was provided for this report.</p>
        }
    </div>

    <!-- Community upvote -->
    <div class="mt-4 d-flex align-items-center gap-3">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <button id="voteBtn"
                    class="btn @(ViewBag.UserHasVoted ? "btn-primary" : "btn-outline-primary") fw-bold"
                    data-report-id="@Model.Id"
                    data-voted="@ViewBag.UserHasVoted.ToString().ToLower()">
                <i class="fa-solid fa-thumbs-up me-1"></i>
                I've seen this too
            </button>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary fw-bold">
                <i class="fa-solid fa-thumbs-up me-1"></i>
                I've seen this too
            </a>
        }
        <span class="text-muted">
            <span id="voteCount">@ViewBag.VoteCount</span>
            community vote@(ViewBag.VoteCount == 1 ? "" : "s")
        </span>
    </div>

    <!-- Community fix verification (only shown on Resolved reports) -->
    @if (Model.Status == "Resolved" || Model.Status == "Verified Fixed")
    {
        <div class="mt-3 d-flex align-items-center gap-3">
            @if (Model.Status == "Verified Fixed")
            {
                <span class="badge bg-success fs-6 px-3 py-2">
                    <i class="fa-solid fa-circle-check me-1"></i> Verified Fixed
                </span>
            }
            else if (User.Identity?.IsAuthenticated == true)
            {
                <button id="verifyBtn"
                        class="btn @(ViewBag.UserHasVerified ? "btn-success" : "btn-outline-success") fw-bold"
                        data-report-id="@Model.Id">
                    <i class="fa-solid fa-circle-check me-1"></i>
                    This is fixed
                </button>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-success fw-bold">
                    <i class="fa-solid fa-circle-check me-1"></i>
                    This is fixed
                </a>
            }
            @if (Model.Status == "Resolved")
            {
                <span class="text-muted">
                    <span id="verifyCount">@ViewBag.VerifyCount</span>
                    of @ViewBag.VerifyThreshold verification@(ViewBag.VerifyThreshold == 1 ? "" : "s")
                </span>
            }
        </div>
    }

    <div class="mt-3 d-flex gap-2">
        <a class="btn report-action-btn"
        asp-action="Create"
        aria-label="Report another issue">
            Report another Issue
        </a>

        <a class="btn report-action-btn"
        asp-controller="Home"
        asp-action="Index"
        aria-label="Return to the home page">
            Back to Home
        </a>

        <a class="btn report-action-btn"
        asp-controller="Reports"
        asp-action="Latest"
        aria-label="Return to latest reports">
            View Another Report
        </a>
    </div>
</div>

<!-- Canvas is OUTSIDE the container so viewport units work correctly -->
<canvas id="confetti-canvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:9999;display:none;"></canvas>

@section Scripts {
    @Html.AntiForgeryToken()

    <script src="~/js/reportIssue.js"></script>
    <script src="~/js/reportVote.js" asp-append-version="true"></script>
    <script src="~/js/reportVerify.js" asp-append-version="true"></script>

    <script async defer
        src="https://maps.googleapis.com/maps/api/js?key=@GoogleMaps.Value.ApiKey&callback=initSubmittedMap">
    </script>

     <script src="~/js/confetti.js"></script>

        @if (TempData["Success"] != null)
        {
            <text><script>setTimeout(launchConfetti, 500);</script></text>
        }
    
}
