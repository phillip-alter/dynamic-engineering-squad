@using InfrastructureApp.Configuration
@using Microsoft.Extensions.Options

<!--injects API key, avoids using viewbag-->
@inject IOptions<GoogleMapsOptions> GoogleMaps


@model InfrastructureApp.Models.ReportIssue
@{
    ViewData["Title"] = "Report Submitted";
}

<div class="container py-4">
    <h1 class="h3 mb-3">Report Submitted</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Success"]
        </div>
    }

    <div class="report-card">
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Created:</strong> @Model.CreatedAt</p>
        <p><strong>Description:</strong><br />@Model.Description</p>
        <p><strong>Location:</strong> (@Model.Latitude, @Model.Longitude)</p>

        <div class="mt-3">
            <p><strong>Location on map:</strong></p>

            <div id="submittedMap"
                data-lat="@Model.Latitude"
                data-lng="@Model.Longitude"
                style="height:320px; width:100%; border-radius:12px;">
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <p><strong>Image:</strong></p>
            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="Uploaded issue photo" />
        }
    </div>

    <div class="mt-3 d-flex gap-2">
        <a class="btn report-action-btn"
        asp-action="Create"
        aria-label="Report another issue">
            Report another Issue
        </a>

        <a class="btn report-action-btn"
        asp-controller="Home"
        asp-action="Index"
        aria-label="Return to the home page">
            Back to Home
        </a>
    </div>
    <canvas id="confetti-canvas" style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;display:none;"></canvas>
</div>



@section Scripts {

    <script src="~/js/reportIssue.js"></script>

    <script async defer
        src="https://maps.googleapis.com/maps/api/js?key=@GoogleMaps.Value.ApiKey&callback=initSubmittedMap">
    </script>

     <script>
        (function () {
            const canvas = document.getElementById('confetti-canvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let animationId = null;

            const COLORS = ['#ff595e','#ffca3a','#6a4c93','#1982c4','#8ac926','#ff924c','#c77dff'];
            const SHAPES = ['circle', 'rect', 'triangle'];

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resize);

            function randomBetween(a, b) { return a + Math.random() * (b - a); }

            function createParticle() {
                return {
                    x: randomBetween(0, canvas.width),
                    y: randomBetween(-80, -10),
                    size: randomBetween(7, 16),
                    color: COLORS[Math.floor(Math.random() * COLORS.length)],
                    shape: SHAPES[Math.floor(Math.random() * SHAPES.length)],
                    speedY: randomBetween(3, 7),
                    speedX: randomBetween(-2, 2),
                    rotation: randomBetween(0, Math.PI * 2),
                    rotationSpeed: randomBetween(-0.08, 0.08),
                    opacity: 1
                };
            }

            function drawParticle(p) {
                ctx.save();
                ctx.globalAlpha = p.opacity;
                ctx.fillStyle = p.color;
                ctx.translate(p.x, p.y);
                ctx.rotate(p.rotation);

                if (p.shape === 'circle') {
                    ctx.beginPath();
                    ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
                    ctx.fill();
                } else if (p.shape === 'rect') {
                    ctx.fillRect(-p.size / 2, -p.size / 4, p.size, p.size / 2);
                } else {
                    ctx.beginPath();
                    ctx.moveTo(0, -p.size / 2);
                    ctx.lineTo(p.size / 2, p.size / 2);
                    ctx.lineTo(-p.size / 2, p.size / 2);
                    ctx.closePath();
                    ctx.fill();
                }
                ctx.restore();
            }

            function update() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles.forEach(p => {
                    p.y += p.speedY;
                    p.x += p.speedX;
                    p.rotation += p.rotationSpeed;
                    if (p.y > canvas.height - 60) p.opacity -= 0.04;
                    drawParticle(p);
                });
                particles = particles.filter(p => p.opacity > 0 && p.y < canvas.height + 20);

                if (particles.length > 0) {
                    animationId = requestAnimationFrame(update);
                } else {
                    canvas.style.display = 'none';
                    cancelAnimationFrame(animationId);
                }
            }

            function launchConfetti() {
                resize();
                canvas.style.display = 'block';
                let waves = 0;
                const interval = setInterval(() => {
                    for (let i = 0; i < 30; i++) particles.push(createParticle());
                    if (++waves >= 8) clearInterval(interval);
                }, 150);
                if (animationId) cancelAnimationFrame(animationId);
                update();
            }

            window.launchConfetti = launchConfetti;
        })();

        @if (TempData["SubmissionSuccess"] != null && (bool)TempData["SubmissionSuccess"])
        {
            <text>document.addEventListener('DOMContentLoaded', function () { window.launchConfetti(); });</text>
        }
    </script>

}