@model InfrastructureApp.ViewModels.Account.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />

<div class="account-container">
    <div class="account-box">
        <h2 class="text-center mb-4">Reset Password</h2>
        
        @if (TempData["ResetPasswordMessage"] != null)
        {
            <div class="alert alert-info">
                @TempData["ResetPasswordMessage"]
            </div>
            <div class="text-center">
                <a asp-action="Login" class="btn btn-primary">Go to Login</a>
            </div>
        }
        else
        {
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success w-100 p-2">Reset Password</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
