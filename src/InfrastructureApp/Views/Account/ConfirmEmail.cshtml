@{
    ViewData["Title"] = "Confirm Email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-4 text-success">Email Confirmed!</h1>
            <p class="lead">Thank you for confirming your email address.</p>
            <p>Your account is now fully active.</p>
            
            <div class="mt-4">
                <a asp-action="Login" class="btn btn-primary">Login Now</a>
            </div>
        </div>
    </div>
</div>
