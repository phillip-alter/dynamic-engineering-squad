@model InfrastructureApp.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />

<div class="account-container">
    <div class="account-box">
        <h2 class="text-center mb-4">Forgot Password</h2>
        
        @if (TempData["ForgotPasswordMessage"] != null)
        {
            <div class="alert alert-info">
                @TempData["ForgotPasswordMessage"]
            </div>
            <div class="text-center">
                <a asp-action="Login" class="btn btn-primary">Back to Login</a>
            </div>
        }
        else
        {
            <p class="text-muted small">
                Enter your email address and we'll send you a link to reset your password.
            </p>
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success w-100 p-2">Send Reset Link</button>
            </form>
            <div class="text-center mt-3">
                <a asp-action="Login" class="text-decoration-none">Back to Login</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
