@model InfrastructureApp.Models.ReportIssue

@{
    ViewData["Title"] = "Report Details";
}

<div class="container py-4">
    <h1 class="h3 mb-4">Report Details</h1>

    <div class="card shadow-sm">
        <div class="card-body">
            <p><strong>Description:</strong><br />@Model.Description</p>
            <p><strong>Status:</strong> @Model.Status</p>
            <p><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("f")</p>

            <p><strong>Location:</strong></p>
            <p class="mb-3">
                Latitude: @Model.Latitude <br />
                Longitude: @Model.Longitude
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <p><strong>Image:</strong></p>
                <img src="@Model.ImageUrl" class="img-fluid rounded border" alt="Report image" />
            }
            else
            {
                <p class="text-muted">No image was provided for this report.</p>
            }

            <div class="mt-4">
                <a asp-controller="Reports" asp-action="Latest" class="btn btn-secondary">Back to Latest Reports</a>
            </div>
        </div>
    </div>
</div>