@model InfrastructureApp.ViewModels.LeaderboardIndexViewModel

<!--
    This view is strongly typed to LeaderboardIndexViewModel.
    The controller is responsible for populating this model before passing it to the view.-->


<div class="d-flex align-items-center gap-3 mb-1">
    <h1 class="mb-0"><i class="fa-solid fa-trophy me-2 text-safety-yellow"></i>Leaderboard</h1>
</div>
<p class="text-muted mb-4">Top <strong class="text-safety-orange">@Model.TopN</strong> contributors</p>

@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">
        <i class="fa-solid fa-circle-info me-2"></i><em>No contributions yet.</em>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr style="border-bottom: 2px solid var(--safety-orange);">
                        <th style="color: var(--safety-yellow);">Rank</th>
                        <th style="color: var(--safety-yellow);">User</th>
                        <th style="color: var(--safety-yellow);">Points</th>
                        <th style="color: var(--safety-yellow);">Updated</th>
                    </tr>
                </thead>
                <tbody>
@{
    int rank = 1;
}
@foreach (var entry in Model.Entries)
{
    <tr>
        <td>
            @if (rank == 1)
            {
                <span class="badge" style="background-color: #FFD600; color: #1a1a1a; font-size: 0.85rem;">🥇 1</span>
            }
            else if (rank == 2)
            {
                <span class="badge" style="background-color: #A8A8A8; color: #1a1a1a; font-size: 0.85rem;">🥈 2</span>
            }
            else if (rank == 3)
            {
                <span class="badge" style="background-color: #FF6600; color: #fff; font-size: 0.85rem;">🥉 3</span>
            }
            else
            {
                <span class="text-muted">@rank</span>
            }
        </td>
        <td class="fw-semibold">@entry.UserId</td>
        <td><span class="text-safety-blue fw-bold">@entry.UserPoints</span></td>
        <td class="text-muted small">@entry.UpdatedAtUtc.ToLocalTime().ToString("g")</td>
    </tr>

    rank++;
}
                </tbody>
            </table>
        </div>
    </div>
}
