@model InfrastructureApp.ViewModels.Minigames.MinigamesIndexViewModel

@{
    ViewData["Title"] = "Minigames";
}

<link rel="stylesheet" href="~/css/minigames.css" asp-append-version="true" />

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-gamepad me-2 text-warning"></i>Minigames</h1>
        <p class="text-muted mb-0">Infrastructure-themed games with server-side daily point awards.</p>
    </div>
    <div class="card border-0 shadow-sm minigame-balance-card">
        <div class="card-body">
            <div class="text-muted text-uppercase small">Current Balance</div>
            <div class="fs-3 fw-bold text-warning" data-testid="minigames-current-points">@Model.CurrentPoints</div>
            <div class="small text-muted">available points</div>
        </div>
    </div>
</div>

<div class="row g-4">
    @foreach (var game in Model.Games)
    {
        var buttonText = game.HasReachedDailyLimit
            ? "Maxed Today"
            : game.IsAvailable
                ? "Play"
                : "Coming Soon";

        <div class="col-md-6 col-xl-3">
            <div class="card h-100 shadow-sm minigame-card" data-testid="minigame-card" data-game-key="@game.GameKey">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <h5 class="card-title mb-0">@game.Name</h5>
                        <span class="badge text-bg-warning">@game.PointsAvailable pts</span>
                    </div>
                    <p class="text-muted flex-grow-1">@game.Description</p>
                    <div class="small mb-3">
                        <div class="text-muted mb-1">
                            Progress today: <strong>@game.DailyPointsEarned / @game.PointsAvailable</strong>
                        </div>

                        @if (game.HasReachedDailyLimit)
                        {
                            <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i>Daily point limit reached</span>
                        }
                        else if (game.IsAvailable)
                        {
                            <span class="text-info"><i class="fa-solid fa-circle-play me-1"></i>Ready to play</span>
                        }
                        else
                        {
                            <span class="text-secondary"><i class="fa-solid fa-clock me-1"></i>Next slice</span>
                        }
                    </div>

                    @if (game.IsAvailable && !game.HasReachedDailyLimit && !string.IsNullOrWhiteSpace(game.PlayUrl))
                    {
                        <a class="btn btn-primary mt-auto" href="@game.PlayUrl">
                            @buttonText
                        </a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary mt-auto" disabled>@buttonText</button>
                    }
                </div>
            </div>
        </div>
    }
</div>
