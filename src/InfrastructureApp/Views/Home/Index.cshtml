@model List<InfrastructureApp.Models.ReportIssue>
@{
    ViewData["Title"] = "Mission Control";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Welcome back, Pathfinder.</h1>
    <p class="lead text-muted">
        The city infrastructure is crumbling. Time to grind some XP.
    </p>
</div>

<div class="text-center mb-4">
    <a asp-controller="Leaderboard" asp-action="Index" class="btn btn-success btn-lg fw-bold">
        <i class="fa-solid fa-trophy me-2"></i> View Leaderboard
    </a>
</div>

<div class="row text-center mb-5">
    <!-- Report Issue Card -->
    <div class="col-md-6 mb-3">
        <div class="card bg-dark text-white border-info h-100 shadow-lg">
            <div class="card-body d-flex flex-column justify-content-center align-items-center p-5">
                <i class="fa-solid fa-camera fa-4x mb-3 text-info"></i>
                <h2 class="card-title">Report Issue</h2>
                <p class="card-text">
                    Spot a pothole or broken light? Snap it, tag it, claim the bounty.
                </p>
                <a asp-controller="ReportIssue" asp-action="Create"
                   class="btn btn-lg btn-info mt-auto fw-bold">
                    Start Quest
                </a>
            </div>
        </div>
    </div>

    <!-- Verify Fixes Card -->
    <div class="col-md-6 mb-3">
        <div class="card bg-dark text-white border-warning h-100 shadow-lg">
            <div class="card-body d-flex flex-column justify-content-center align-items-center p-5">
                <i class="fa-solid fa-check-double fa-4x mb-3 text-warning"></i>
                <h2 class="card-title">Verify Fixes</h2>
                <p class="card-text">
                    Confirm repairs made by the city to earn Reputation Points.
                </p>
                <a asp-controller="Reports" asp-action="Verify"
                   class="btn btn-lg btn-warning mt-auto fw-bold text-dark">
                    Verify Now
                </a>
            </div>
        </div>
    </div>
</div>

<h3 class="border-bottom pb-2 mb-3"> <i class="fa-solid fa-rss"></i> Recent Activity in Your Zone </h3>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No recent reports are available right now.
    </div>
}
else
{
    <div class="list-group">
        @foreach (var report in Model)
        {
            <!-- SCRUM-103: display only (NOT clickable yet) -->
            <div class="list-group-item d-flex gap-3 py-3">

                <!-- Icon -->
                <div class="d-flex align-items-center justify-content-center bg-light rounded-circle"
                     style="width: 50px; height: 50px; flex-shrink: 0;">
                    <i class="fa-solid fa-road text-dark fs-4"></i>
                </div>

                <!-- Content -->
                <div class="d-flex gap-2 w-100 justify-content-between">
                    <div>
                        <h6 class="mb-0">@report.Description</h6>
                        <p class="mb-0 opacity-75">
                            <span class="badge bg-secondary">@report.Status</span>
                        </p>
                    </div>

                    <small class="opacity-50 text-nowrap">
                        @report.CreatedAt.ToLocalTime().ToString("g")
                    </small>
                </div>
            </div>
        }
    </div>
}

<!-- SCRUM-103: link to full Latest Reports page -->
<div class="mt-3">
    <a asp-controller="Reports" asp-action="Latest" class="btn btn-outline-primary">
        View All Latest Reports
    </a>
</div>