@model List<InfrastructureApp.Models.ReportIssue>
@{
    ViewData["Title"] = "Mission Control";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Welcome back, Pathfinder.</h1>
    <p class="lead text-muted">
        The city infrastructure is crumbling. Time to grind some XP.
    </p>
</div>

<div class="text-center mb-4">
    <a asp-controller="Leaderboard" asp-action="Index" class="btn btn-primary btn-lg fw-bold">
        <i class="fa-solid fa-trophy me-2"></i> View Leaderboard
    </a>
</div>

<div class="row text-center mb-5">
    <!-- Report Issue Card -->
    <div class="col-md-6 mb-3">
        <div class="card clickable h-100" style="border-top: 3px solid var(--safety-orange);">
            <div class="card-body d-flex flex-column justify-content-center align-items-center p-5">
                <i class="fa-solid fa-camera fa-4x mb-3 text-safety-orange"></i>
                <h2 class="card-title">Report Issue</h2>
                <p class="card-text">
                    Spot a pothole or broken light? Snap it, tag it, claim the bounty.
                </p>
                <a asp-controller="ReportIssue" asp-action="Create" class="btn btn-lg btn-danger mt-auto fw-bold">
                    Start Quest
                </a>
            </div>
        </div>
    </div>

    <!-- Verify Fixes Card -->
    <div class="col-md-6 mb-3">
        <div class="card clickable h-100" style="border-top: 3px solid var(--safety-yellow);">
            <div class="card-body d-flex flex-column justify-content-center align-items-center p-5">
                <i class="fa-solid fa-check-double fa-4x mb-3 text-safety-yellow"></i>
                <h2 class="card-title">Verify Fixes</h2>
                <p class="card-text">
                    Confirm repairs made by the city to earn Reputation Points.
                </p>
                <a asp-controller="Reports" asp-action="Verify"
                       class="btn btn-lg btn-warning mt-auto fw-bold">
                    Verify Now
                </a>
            </div>
        </div>
    </div>
</div>

<h3 id="recentReportsHeading" class="border-bottom pb-2 mb-3"> <i class="fa-solid fa-rss"></i> Recent Activity in Your
    Zone </h3>

    @if (Model == null || !Model.Any())
    {
        <div id="noRecentReportsMessage" class="alert alert-info">
            No recent reports are available right now.
        </div>
    }
    else
    {
        <div id="recentReportsList" class="list-group">
            @foreach (var report in Model)
            {
                <!-- SCRUM-113 ADDED:
                 Each report row is now interactive and stores report Id for JS navigation -->
                <div class="list-group-item d-flex gap-3 py-3 home-report-item" data-reportid="@report.Id" tabindex="0"
                     role="button" aria-label="Open details for report @report.Id">

                    <!-- Icon -->
                    <div class="d-flex align-items-center justify-content-center bg-light rounded-circle"
                         style="width: 50px; height: 50px; flex-shrink: 0;">
                        <i class="fa-solid fa-road text-dark fs-4"></i>
                    </div>

                    <!-- Content -->
                    <div class="d-flex gap-2 w-100 justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-0">@report.Description</h6>
                            <p class="mb-0 opacity-75">
                                <span class="badge bg-secondary">@report.Status</span>
                            </p>
                        </div>

                        <!-- SCRUM-113 ADDED:
                         Added View Details text so users know row is clickable -->
                        <div class="text-end">
                            <small class="opacity-50 text-nowrap d-block">
                                @report.CreatedAt.ToLocalTime().ToString("g")
                            </small>
                            <small class="text-primary fw-semibold home-report-link-text">View Details</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- SCRUM-103: link to full Latest Reports page -->
    <div class="mt-3">
        <a id="viewAllLatestReportsButton" asp-controller="Reports" asp-action="Latest" class="btn btn-outline-primary">
            View All Latest Reports
        </a>
    </div>

    @section Scripts {
        <!-- SCRUM-113 ADDED:
         Handles click and keyboard navigation for Home page recent reports -->
        <script src="~/js/homeRecentReports.js" asp-append-version="true"></script>
    }